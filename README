PROJECT STRUCTURE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

stephansdom/
├── backend/
│   ├── main.py              FastAPI app entry point
│   ├── database.py          SQLAlchemy connection (reads DATABASE_URL from env)
│   ├── models.py            Database models: User, TimeEntry, Message
│   ├── schemas.py           Pydantic request/response schemas
│   ├── seed.py              Creates admin + sample employee data
│   ├── Dockerfile           Container definition for the backend
│   └── routers/
│       ├── auth.py          Login, JWT tokens (reads SECRET_KEY from env)
│       ├── time_entries.py  Punch in/out for employees
│       ├── admin.py         Admin management, CSV export, Dienstplan image
│       └── messages.py      Employee → admin inbox
├── frontend/
│   ├── Dockerfile           Builds React app, serves via nginx
│   ├── nginx.conf           Proxies /auth /users /admin /messages to backend
│   ├── vite.config.js       Dev server proxy (mirrors nginx.conf for local dev)
│   ├── .env.local           Local dev env (VITE_API_URL= leave empty)
│   └── src/
│       ├── App.jsx           Auth routing
│       └── pages/
│           ├── Login.jsx     Login screen
│           ├── Dashboard.jsx Employee view (punch in/out, Dienstplan, messages)
│           └── Admin.jsx     Admin view (users, entries, inbox, exports)
├── docker-compose.yml       Defines db + backend + frontend containers
├── .env.example             Template — copy to .env and fill in secrets
├── .env                     !! NOT in git !! Your actual secrets
├── .gitignore
└── pyproject.toml           Python project config and dependencies
