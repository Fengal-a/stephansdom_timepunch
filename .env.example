# Copy this file to .env and fill in your values
# Never commit .env to git

POSTGRES_USER=timepunch
POSTGRES_PASSWORD=changeme
POSTGRES_DB=timepunch

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# Comma-separated list of subnets that employees are allowed to connect from.
# Admins can connect from anywhere regardless of this setting.
# Leave empty to disable the restriction (useful for local development).
OFFICE_NETWORKS=212.186.92.90/32

# Email (Gmail) — for password reset and invite emails
# Use a dedicated Gmail account + App Password (not your main password)
# How to get an App Password: myaccount.google.com → Security → App passwords
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password-here
APP_URL=https://domstempel.at
