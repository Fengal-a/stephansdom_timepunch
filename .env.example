# Copy this file to .env and fill in your values
# Never commit .env to git

POSTGRES_USER=timepunch
POSTGRES_PASSWORD=changeme
POSTGRES_DB=timepunch

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# Comma-separated list of subnets that employees are allowed to connect from.
# Admins can connect from anywhere regardless of this setting.
# Leave empty to disable the restriction (useful for local development).
# Example for a typical office WiFi: 192.168.1.0/24
# Find your office subnet: check your router admin page or run `ip route`
OFFICE_NETWORKS=
